{
  "version": "recurretumulta_familias_v2",
  "objetivo": "Afinar detección de familias para scoring de casos",
  "normalizacion": {
    "uppercase": true,
    "strip_accents": true,
    "trim_spaces": true,
    "collapse_spaces": true,
    "replace": {
      "Á": "A",
      "É": "E",
      "Í": "I",
      "Ó": "O",
      "Ú": "U",
      "Ü": "U",
      "á": "a",
      "é": "e",
      "í": "i",
      "ó": "o",
      "ú": "u",
      "ü": "u"
    }
  },
  "fallback": {
    "generic_only_if_all_scores_zero": true,
    "minimum_score_to_classify": 2,
    "prefer_non_generic_on_tie": true
  },
  "familias": {
    "semaforo": {
      "boost": 3,
      "keywords": [
        "SEMAFORO",
        "FASE ROJA",
        "LUZ ROJA",
        "INDICACION LUMINOSA",
        "SENAL LUMINOSA",
        "DISPOSITIVO LUMINOSO",
        "INTERSECCION REGULADA",
        "CRUZAR EN ROJO",
        "FASE RESTRICTIVA",
        "LINEA DE DETENCION"
      ]
    },
    "atencion": {
      "boost": 3,
      "keywords": [
        "ATENCION",
        "DISTRAIDA",
        "DISTRAIDA",
        "DILIGENCIA DEBIDA",
        "FALTA DE ATENCION",
        "SIN ATENCION SUFICIENTE",
        "CONDUCTA DISTRAIDA",
        "DISMINUYEN LA ATENCION",
        "COMPROMETEN LA ATENCION",
        "CONTROL DEL VEHICULO"
      ]
    },
    "movil": {
      "boost": 3,
      "keywords": [
        "MOVIL",
        "TERMINAL",
        "DISPOSITIVO ELECTRONICO",
        "DISPOSITIVO PORTATIL",
        "PANTALLA DIGITAL",
        "TELEFONICO",
        "TELECOMUNICACIONES",
        "INTERACTUAR CON",
        "MANIPULAR",
        "CONSULTAR PANTALLA",
        "USO DE DISPOSITIVO DURANTE LA CONDUCCION"
      ]
    },
    "auriculares": {
      "boost": 4,
      "keywords": [
        "AURICULAR",
        "AURICULARES",
        "CASCOS",
        "DISPOSITIVOS DE AUDIO",
        "APARATO DE SONIDO",
        "AMBOS OIDOS",
        "AUDIO EN MARCHA",
        "PORTAR AURICULAR",
        "USO DE DISPOSITIVOS DE AUDIO"
      ]
    },
    "casco": {
      "boost": 4,
      "keywords": [
        "CASCO",
        "CASCO DE PROTECCION",
        "CASCO REGLAMENTARIO",
        "CASCO MAL AJUSTADO",
        "CASCO DESABROCHADO",
        "CASCO NO HOMOLOGADO"
      ]
    },
    "condiciones_vehiculo": {
      "boost": 3,
      "keywords": [
        "NEUMATICO",
        "NEUMATICOS",
        "RUEDAS",
        "DEFICIENCIAS TECNICAS",
        "DEFECTOS MECANICOS",
        "FALLO EN SISTEMA DE ILUMINACION",
        "ELEMENTOS DE SEGURIDAD DEFECTUOSOS",
        "DISPOSITIVOS NO HOMOLOGADOS",
        "ALTERACION DE ELEMENTOS LUMINOSOS",
        "VEHICULO CON DEFECTOS"
      ]
    },
    "itv": {
      "boost": 4,
      "keywords": [
        "ITV",
        "INSPECCION TECNICA",
        "INSPECCION TECNICA CADUCADA",
        "SIN ITV",
        "ITV CADUCADA",
        "INSPECCION TECNICA EN VIGOR",
        "SIN INSPECCION TECNICA"
      ]
    },
    "seguro": {
      "boost": 4,
      "keywords": [
        "SEGURO OBLIGATORIO",
        "SIN SEGURO",
        "CARENCIA DE SEGURO",
        "SEGURO EN VIGOR",
        "VEHICULO SIN SEGURO",
        "CARECE DE SEGURO"
      ]
    },
    "carril": {
      "boost": 4,
      "keywords": [
        "CARRIL",
        "CALZADA",
        "POSICION EN LA CALZADA",
        "POSICION INCORRECTA",
        "NO UTILIZAR EL CARRIL DERECHO",
        "CARRIL IZQUIERDO",
        "CIRCULAR POR CARRIL",
        "POSICION EN CALZADA"
      ]
    },
    "marcas_viales": {
      "boost": 4,
      "keywords": [
        "LINEA CONTINUA",
        "MARCA LONGITUDINAL",
        "MARCAS VIALES",
        "REBASAR LINEA CONTINUA",
        "PISAR MARCA",
        "INVADIR ZONA DE MARCAS"
      ]
    },
    "alcohol": {
      "boost": 5,
      "keywords": [
        "ALCOHOL",
        "ALCOHOLEMIA",
        "TASA",
        "TEST DE ALCOHOL",
        "POSITIVO",
        "RESULTADO POSITIVO",
        "TASA SUPERIOR A LA PERMITIDA",
        "BAJO LA INFLUENCIA",
        "BEBIDAS ALCOHOLICAS",
        "DAR POSITIVO"
      ]
    },
    "generic": {
      "boost": 1,
      "keywords": [
        "MANIOBRA IRREGULAR",
        "CONDUCCION IRREGULAR",
        "NO ADAPTAR LA CONDUCCION",
        "MANIOBRA PELIGROSA",
        "NO RESPETAR PREFERENCIA DE PASO"
      ]
    }
  },
  "reglas_extra": [
    {
      "si_contiene_todos": [
        "DISPOSITIVOS DE AUDIO",
        "AMBOS OIDOS"
      ],
      "familia": "auriculares",
      "score": 8
    },
    {
      "si_contiene_todos": [
        "INSPECCION TECNICA",
        "CADUCADA"
      ],
      "familia": "itv",
      "score": 8
    },
    {
      "si_contiene_todos": [
        "TASA",
        "SUPERIOR",
        "PERMITIDA"
      ],
      "familia": "alcohol",
      "score": 7
    },
    {
      "si_contiene_todos": [
        "POSICION",
        "CALZADA"
      ],
      "familia": "carril",
      "score": 7
    },
    {
      "si_contiene_todos": [
        "CARRIL",
        "INCORRECTO"
      ],
      "familia": "carril",
      "score": 7
    },
    {
      "si_contiene_todos": [
        "SIN ATENCION",
        "SUFICIENTE"
      ],
      "familia": "atencion",
      "score": 7
    },
    {
      "si_contiene_todos": [
        "DISPOSITIVO",
        "CONDUCCION"
      ],
      "familia": "movil",
      "score": 5
    }
  ],
  "diagnostico_resumen": {
    "problemas_detectados": [
      "Muchas frases fallidas devuelven todos los scores a 0, señal de que faltan sinónimos exactos.",
      "La familia generic está capturando demasiado cuando debería ser solo último recurso.",
      "Hay expresiones compuestas que requieren reglas por co-ocurrencia, no solo keywords sueltas."
    ],
    "familias_mas_debiles_en_tus_resultados": [
      "carril",
      "auriculares",
      "itv",
      "movil",
      "atencion",
      "alcohol"
    ]
  }
}